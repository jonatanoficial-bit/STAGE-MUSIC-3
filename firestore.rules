rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // Dados privados de cada usuário e todas as subcoleções.
    match /users/{uid}/{document=**} {
      allow read, write: if isOwner(uid);
    }

    // Salas Live autenticadas.
    match /liveRooms/{roomCode} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.code == roomCode;

      allow update: if signedIn()
        && resource.data.status == 'active'
        && request.resource.data.code == resource.data.code
        && request.resource.data.ownerUid == resource.data.ownerUid;

      allow delete: if signedIn()
        && resource.data.ownerUid == request.auth.uid;
    }

    // Teste de conexão das Configurações.
    match /systemChecks/{uid} {
      allow read, write: if isOwner(uid);
    }

    // Bloqueia qualquer caminho não declarado acima.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
